# Amazon Bedrock OpenAI-compatible endpoint for GPT OSS 120B
# Set this to a Bedrock API key, not an OpenAI platform API key.
OPENAI_API_KEY=your-bedrock-api-key-here
OPENAI_BASE_URL=https://bedrock-mantle.us-east-1.api.aws/v1
# BEDROCK_MODEL=openai.gpt-oss-120b

# Optional local LLM mode for Colab/GPU runs
# LOCAL_LLM=true
# LOCAL_LLM_MODEL=Qwen/Qwen3.5-4B-Instruct
# LOCAL_LLM_4BIT=true
# LOCAL_LLM_MAX_NEW_TOKENS=512
# LOCAL_LLM_TEMPERATURE=0.2
# LOCAL_LLM_TOP_P=0.9
# LOCAL_LLM_THINKING=false
